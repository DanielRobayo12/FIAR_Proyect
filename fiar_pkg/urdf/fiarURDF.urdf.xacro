<?xml version="1.0"?>
<robot name="fiar_bot" xmlns:xacro="http://www.ros.org/wiki/xacro">

    <!-- ========= Xacro Import =========-->
    <xacro:include filename="$(find fiar_pkg)/urdf/frontLeg.urdf.xacro" />
    <xacro:include filename="materials.urdf.xacro"/>

    <!-- === base_link ===-->
    <link name="body">
        <visual>
            <geometry>
                <box size="0.30 0.17 0.125"/>
            </geometry>
            <material name="CasterGrey"/>
        </visual>
        <collision>
            <geometry>
                <box size="0.30 0.17 0.125"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.5"/>
            <inertia
                ixx="0.00014167" ixy="0.0" ixz="0.0"
                iyy="0.00074167" iyz="0.0" izz="0.00080833"/>
        </inertial>
    </link>

    <!-- ========= Xacro Include Legs=========-->
    <xacro:front_leg link1="legL1" link2="legL2" wheel="wL1" joint1="LF2" joint2="w1" />
    <xacro:front_leg link1="legR1" link2="legR2" wheel="wR1" joint1="RF2" joint2="w2"/>
    <xacro:front_leg link1="legBackR1" link2="legBackR2" wheel="wR2" joint1="RB2" joint2="w3"/>
    <xacro:front_leg link1="legBackL1" link2="legBackL2" wheel="wL2" joint1="LB2" joint2="w4"/>
    <!-- === Xacro Include Head ====-->
    <xacro:topHead head="head" neck="neck"/>

    <!-- === leg1_to_body ===-->
    <joint name="LF1" type="revolute">
        <parent link="body"/>
        <child link="legL1"/>
        <origin xyz="0.125 0.1 0" rpy="1.5707 0 0"/>
        <axis xyz="0 0 1"/>
        <limit lower="-3.1415" upper="0" effort="10" velocity="2"/>
        <dynamics damping="1" friction="1"/>
    </joint>
    <!-- === leg2_to_body ===-->
    <joint name="RF1" type="revolute">
        <parent link="body"/>
        <child link="legR1"/>
        <origin xyz="0.125 -0.1 0" rpy="-1.5707 0 0"/>
        <axis xyz="0 0 -1"/>
        <limit lower="-3.1415" upper="0" effort="10" velocity="2"/>
        <dynamics damping="1" friction="1"/>
    </joint>

    <!-- === leg3_to_body === -->
    <joint name="RB1" type="revolute"> 
        <parent link="body"/>
        <child link="legBackR1"/>
        <origin xyz="-0.125 0.1 0" rpy="1.5707 0 0"/>
        <axis xyz="0 0 1"/>
        <limit lower="-3.1415" upper="0" effort="10" velocity="2"/>
        <dynamics damping="1" friction="1"/>
    </joint>
    
    <!-- === leg4_to_body ===-->
    <joint name="LB1" type="revolute">
        <parent link="body"/>
        <child link="legBackL1"/>
        <origin xyz="-0.125 -0.1 0" rpy="-1.5707 0 0"/>
        <axis xyz="0 0 -1"/>
        <limit lower="-3.1415" upper="0" effort="10" velocity="2"/>
         <dynamics damping="1" friction="1"/>
    </joint>

    <!-- === Head to Body ===-->
    <joint name="neck_to_body" type="revolute">
        <parent link="body"/>
        <child link="neck"/>
        <origin xyz="0.14 0 0.0875"/>
        <axis xyz="0 0 1"/>
        <limit lower="-3.1415" upper="0" effort="10" velocity="2"/>
         <dynamics damping="1" friction="1"/>
    </joint>


<!-- Control interface -->
  <xacro:include filename="$(find fiar_pkg)/urdf/controls.urdf.xacro"/>
</robot>
