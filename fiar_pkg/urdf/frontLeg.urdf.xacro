<?xml version="1.0"?>
<robot name="front_leg" xmlns:xacro="http://www.ros.org/wiki/xacro">

    <xacro:include filename="materials.urdf.xacro"/>

    

    <xacro:materials/>

    <!-- ============================ XACRO 1 ==============================-->
  <xacro:macro name="front_leg" params="link1 link2 wheel joint1 joint2">
     <!-- === LINK 1 ====-->
    <link name="${link1}">
        
        <visual>
            <geometry>
                <box size="0.13 0.05 0.03"/>
            </geometry>
            <material name="TopBlack"/>
            <origin xyz="0.075 0 0"/>
        </visual>
        <collision>
            <geometry>
                <box size="0.13 0.05 0.03"/>
            </geometry>
            <origin xyz="0.075 0 0"/>
        </collision>
        <inertial>
            <mass value="0.5"/>
            <inertia
                ixx="0.00014167" ixy="0.0" ixz="0.0"
                iyy="0.00074167" iyz="0.0" izz="0.00080833"/>
        </inertial>
    </link>

     <!-- === LINK 2 ====-->
     <link name="${link2}">
        <visual>
            <geometry>
                <box size="0.13 0.05 0.03"/>
            </geometry>
            <origin xyz="0.075 0 0"/>
        </visual>
        <collision>
            <geometry>
                <box size="0.13 0.05 0.03"/>
            </geometry>
            <origin xyz="0.075 0 0"/>
        </collision>
        <inertial>
            <mass value="0.5"/>
            <inertia
                ixx="0.00014167" ixy="0.0" ixz="0.0"
                iyy="0.00074167" iyz="0.0" izz="0.00080833"/>
        </inertial>
     </link>

     <!-- === wheel ====-->
     <link name="${wheel}">
        <visual>
            <geometry>
                <cylinder radius="0.0325" length="0.02"/>
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.0325" length="0.02"/>
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </collision>
        <inertial>
            <mass value="0.1"/>
            <inertia
                ixx="0.00002974" ixy="0.0" ixz="0.0"
                iyy="0.00002974" iyz="0.0" izz="0.00005281"/>
        </inertial>
     </link>
     

     <!-- === Joint leg to leg ====-->
     <joint  name="${joint1}" type="revolute">
            <parent link="${link1}"/>
            <child link="${link2}"/>
            <origin xyz="0.10 0 0.03"/>
            <axis xyz="0 0 1"/>
            <limit lower="-2" upper="2" effort="0.01" velocity="0.4"/>
            <dynamics damping="1" friction="1"/>
     </joint>

     <!-- === Joint wheel to leg ====-->
     <joint name="${joint2}" type="continuous">
        <parent link="${link2}"/>
        <child link="${wheel}"/>
        <origin xyz="0.13 0 -0.025" rpy="0 0 -1.5707"/>
        <axis xyz="0 0 1"/>
        <dynamics damping="1" friction="1"/>
     </joint>
    
</xacro:macro>
 <!-- ============================ XACRO 2 ==============================-->
<xacro:macro name="topHead" params="head neck">
    <link name="${neck}">
        <visual>
            <geometry>
                <cylinder radius="0.04" length="0.05"/>
            </geometry>
            <material name="HubcapYellow"/>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.05" length="0.05"/> 
            </geometry>
        </collision>
        <inertial>
            <mass value="0.1"/>
            <inertia
                ixx="0.00002974" ixy="0.0" ixz="0.0"
                iyy="0.00002974" iyz="0.0" izz="0.00005281"/>
        </inertial>
    </link>

    <!-- === head === -->
    <link name="${head}">
        <visual>
            <geometry>
                <cylinder radius="0.07" length="0.1"/>
            </geometry>
            <material name="SonarYellow"/>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.13" length="0.1"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.1"/>
            <inertia
                ixx="0.00002974" ixy="0.0" ixz="0.0"
                iyy="0.00002974" iyz="0.0" izz="0.00005281"/>
        </inertial>
    </link>

     <!-- === Head to neck ===-->
    <joint name="head_to_neck" type="revolute">
        <parent link="${neck}"/>
        <child link="${head}"/>
        <origin xyz="0 0 0.155" rpy="0 1.57 0"/>
        <axis xyz="0 0 1"/>
        <limit lower="0" upper="-3.1415" effort="0.01" velocity="0.4"/>
         <dynamics damping="1" friction="1"/>
    </joint>
</xacro:macro>


</robot>